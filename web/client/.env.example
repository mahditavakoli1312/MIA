# Copy to .env and fill in from the Android project's local.properties:
#
#   local.properties key   ->  client .env key
#   SUPABASE_URL           ->  VITE_SUPABASE_URL
#   SUPABASE_ANON_KEY      ->  VITE_SUPABASE_ANON_KEY
#
# These two are SAFE to expose: Supabase's anon key is public by design and access
# is scoped per-user by Row-Level Security, exactly as in the Android app.
#
# GAPGPT_API_KEY and GITHUB_TOKEN do NOT go here — they live in web/server/.env.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Base URL of the proxy. In dev, Vite proxies /api -> http://localhost:8787, so
# leaving this empty means requests go to same-origin /api/*. Set it only for prod.
VITE_API_BASE=

{
  "name": "mia-web-server",
  "version": "1.0.0",
  "private": true,
  "description": "Proxy backend for MIA web — holds the OpenRouter (LLM) key and GitHub token so they never reach the browser.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  }
}

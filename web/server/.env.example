# Copy to .env and fill in. These mirror the secrets in the Android project's
# local.properties. The server keeps them private; the browser never sees them.
#
#   local.properties key  ->  server .env key
#   GAPGPT_API_KEY        ->  GAPGPT_API_KEY
#   GITHUB_TOKEN          ->  GITHUB_TOKEN   (leave blank to disable GitHub mirroring)

# OpenRouter-compatible endpoint used by the Android app (api.gapgpt.app).
GAPGPT_API_KEY=

# GitHub Personal Access Token with 'repo' scope. Leave blank to disable mirroring.
GITHUB_TOKEN=

# Port the proxy listens on. Vite dev server proxies /api -> http://localhost:8787
PORT=8787

# Allowed browser origin for CORS in dev.
CORS_ORIGIN=http://localhost:5173

# Passed through to the LLM for routing (OpenRouter convention).
HTTP_REFERER=http://localhost:5173
APP_TITLE=MIA Web
